# ========================
# Terraform
# ========================

# Local .terraform directories
**/.terraform/*

# .tfstate files (state contains sensitive data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (likely contain sensitive data)
# Use .tfvars.example as templates
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan output files
*tfplan*
*.tfplan

# Terraform lock file (include in VCS for reproducible builds)
!.terraform.lock.hcl

# ========================
# Secrets & Credentials
# ========================
*.pem
*.key
*.pub
*.pfx
*.p12
*credentials*
*secret*
.env
.env.*

# ========================
# OS-Specific
# ========================
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ========================
# IDE & Editor
# ========================
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ========================
# Logs
# ========================
*.log
logs/
